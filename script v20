function getHumanoidRootPart()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart") or nil
end
function startInstaPrompt()
    if InstaPrompt.conn then return end
    InstaPrompt.on = true
    InstaPrompt.conn = true
    -- One-time scan: set HoldDuration = 0 and save originals for restore
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.ClassName == "ProximityPrompt" then
            InstaPrompt.prompts[v] = v.HoldDuration
            pcall(function() v.HoldDuration = 0 end)
        end
    end
    -- Catch any new prompts that spawn later — no polling needed
    InstaPrompt.listConn = workspace.DescendantAdded:Connect(function(v)
        if v.ClassName == "ProximityPrompt" then
            InstaPrompt.prompts[v] = v.HoldDuration
            pcall(function() v.HoldDuration = 0 end)
        end
    end)
end
function stopInstaPrompt()
    InstaPrompt.on = false
    InstaPrompt.conn = nil
    if InstaPrompt.listConn then InstaPrompt.listConn:Disconnect() InstaPrompt.listConn = nil end
    -- Restore original hold durations
    for pp, orig in pairs(InstaPrompt.prompts) do
        pcall(function() pp.HoldDuration = orig end)
    end
    table.clear(InstaPrompt.prompts)
end
function getRootPart(o)
    if o:IsA("Model") then
        return o:FindFirstChild("HumanoidRootPart") or o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart")
    elseif o:IsA("BasePart") then
        return o
    end
    return nil
end
-- FIX: single interactWith definition (duplicate removed from dungeon section)
function interactWith(obj)
    if not obj then return end
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        -- Set HoldDuration=0 first (MacSploit compatible — no fireproximityprompt needed)
        pcall(function() prompt.HoldDuration = 0 end)
        pcall(function() fireproximityprompt(prompt) end)
