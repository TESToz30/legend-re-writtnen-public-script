-- =====================================================
function killObj(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter") or obj:IsA("Sparkles") or obj:IsA("Fire") or obj:IsA("Smoke") then
            obj.Enabled = false obj.Rate = 0
        elseif obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("PointLight") then
            obj.Enabled = false
        elseif obj:IsA("SurfaceGui") then
            obj.Enabled = false
        elseif (obj:IsA("Model") or obj:IsA("Part") or obj:IsA("MeshPart")) and VFX_MODEL_NAMES[obj.Name] then
            obj.LocalTransparencyModifier = 1
            for _, d in ipairs(obj:GetDescendants()) do killObj(d) end
        end
    end)
end
function disableVFX(char)
    if not char then return end
    for _, obj in ipairs(char:GetDescendants()) do
        if VFX_MODEL_NAMES[obj.Name] or VFX_CLASSES[obj.ClassName] then killObj(obj) end
    end
end
function hookChar(char)
    if VFX.conn then VFX.conn:Disconnect() end
    VFX.conn = char.DescendantAdded:Connect(function(obj)
        if not VFX.on then return end
        if VFX_MODEL_NAMES[obj.Name] or VFX_CLASSES[obj.ClassName] then
            task.defer(function() killObj(obj) end)
        end
    end)
end
function startVFXReducer()
    if VFX.on then return end
    VFX.on = true
    local char = LocalPlayer.Character
    if char then disableVFX(char) hookChar(char) end
end
function stopVFXReducer()
    VFX.on = false
    if VFX.conn then VFX.conn:Disconnect() VFX.conn = nil end
end
LocalPlayer.CharacterAdded:Connect(function(char)
    if not VFX.on then return end
    task.wait(1)
    disableVFX(char)
    hookChar(char)
end)

