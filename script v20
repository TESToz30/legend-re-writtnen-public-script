function startFloat()
    local h = getHumanoidRootPart()
    if not h or h:FindFirstChild("_F") then return end
    local b = Instance.new("BodyPosition")
    b.Name = "_F"
    b.MaxForce = Vector3.new(0, math.huge, 0) -- Y only: cheap on physics
    b.D = 1000
    b.P = 20000
