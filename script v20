            climbConn = hum.StateChanged:Connect(function(_, new)
                if new == Enum.HumanoidStateType.Climbing then
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                end
            end)
            hum:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
        end
    end
