function applyPreset(pr)
    if type(pr) ~= "table" then return end
    if pr.hover then HOVER = pr.hover end
    if pr.speed then MOVEMENT_CONFIG.Speed = pr.speed end
    if pr.octR then OCT_R = pr.octR end
    if pr.potionThreshold then autoPotionThreshold = pr.potionThreshold end
    if pr.staticHover ~= nil then Farm.staticHover = pr.staticHover end
    pcall(function()
        if ToggleSetters.applyRank then ToggleSetters.applyRank(pr.gRank) end
        if ToggleSetters.applyGateType then ToggleSetters.applyGateType(pr.gType) end
    end)
    local function ss(k, v) local s = ToggleSetters[k] if s then pcall(s, v == true) end end
    ss("noclip", pr.noclip) ss("espP", pr.espP) ss("espM", pr.espM)
    ss("autoAb", pr.autoAb) ss("infStam", pr.infStam) ss("vfx", pr.vfx)
    ss("doorESP", pr.doorESP) ss("exitESP", pr.exitESP) ss("chestESP", pr.chestESP)
    ss("mobESP", pr.mobESP) ss("trapESP", pr.trapESP)
    if pr.raidOn and not Raid.on and startUrukRaid then pcall(task.spawn, startUrukRaid) end
    if type(pr.selectedMobs) == "table" then for k in pairs(SelectedMobs) do SelectedMobs[k] = nil end for k, v in pairs(pr.selectedMobs) do SelectedMobs[k] = v end end
