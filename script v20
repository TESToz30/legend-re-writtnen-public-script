    local function runInventoryScan(folderNames)
        clearResults() tradeCountLbl.Text = "Scanning..."
        local totalNonZero = 0 local totalValue = 0
        for _, folderName in ipairs(folderNames) do
            local folder = selectedPlayer:FindFirstChild(folderName)
            if not folder then
                addLine("[ " .. folderName .. " ] — NOT FOUND", C.RED, true) addLine("", C.TXT, true)
            else
                local items = {}
                for _, item in ipairs(folder:GetChildren()) do
                    local val = item:IsA("ValueBase") and item.Value or 1
                    if val ~= 0 then table.insert(items, { name = item.Name, value = item:IsA("ValueBase") and tostring(item.Value) or "(object)" }) end
                end
                table.sort(items, function(a, b) return a.name < b.name end)
                local folderValue = 0
                for _, item in ipairs(items) do
                    local price = ITEM_VALUES[item.name] or 0
                    local qty = tonumber(item.value) or 1
                    folderValue = folderValue + (price * qty)
                end
                totalValue = totalValue + folderValue totalNonZero = totalNonZero + #items
                addLine("[ " .. folderName .. " ]  (" .. #items .. " items)  ~" .. string.format("%.2f", folderValue / 1000000) .. "mil Gold", C.ACNT, true)
                addLine(string.rep("-", 38), C.SUB, true)
                if #items == 0 then
                    addLine("  (empty)", C.SUB)
                else
                    for _, item in ipairs(items) do
                        local price = ITEM_VALUES[item.name] or 0
                        local pad = string.rep(" ", math.max(1, 28 - #item.name))
                        local vs = price > 0 and "  [" .. price .. "g]" or ""
                        addLine("  " .. item.name .. pad .. item.value .. vs, C.TXT)
                    end
                end
                addLine("", C.TXT, true)
            end
            task.wait()
        end
        tradeCountLbl.Text = "Items: " .. totalNonZero .. "  |  Total: ~" .. string.format("%.2f", totalValue / 1000000) .. "mil Gold"
    end
    mkSec(TRT, "SCAN")
