function dungTweenTo(part)
    local hrp = getHumanoidRootPart()
    if not hrp or not part then return end
    local d = (hrp.Position - part.Position).Magnitude
    local tw = TS:Create(hrp, TweenInfo.new(math.clamp(d / MOVEMENT_CONFIG.Speed, 0.05, 4), MOVEMENT_CONFIG.Style, MOVEMENT_CONFIG.Direction), { CFrame = CFrame.new(part.Position + Vector3.new(0, DUNG_OFFSET, 0)) })
    tw:Play()
    tw.Completed:Wait()
end
function dungCFrameTo(part)
    local hrp = getHumanoidRootPart()
    if not hrp or not part then return end
    hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, DUNG_OFFSET, 0))
end
function dungMoveTo(part)
    if Dungeon.instantTP then dungCFrameTo(part) else dungTweenTo(part) end
end
function getObjects(names)
    local hrp = getHumanoidRootPart()
    if not hrp then return {} end
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("BasePart") then
            for _, n in ipairs(names) do
                if string.find(obj.Name, n, 1, true) then
                    local part = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or (obj:IsA("BasePart") and obj or nil)
                    if part then  -- nil when obj is a pure container Model with no BasePart
                        table.insert(found, { obj = obj, part = part, dist = (hrp.Position - part.Position).Magnitude })
                    end
                    break
                end
            end
        end
    end
    table.sort(found, function(a, b) return a.dist < b.dist end)
    return found
end
function nearestObj(names) local list = getObjects(names) return list[1] end
-- Fast door lookup: uses CachedDoors (maintained by scanAllDoors + DescendantAdded)
-- Falls back to getObjects only if cache is empty
function getDoorObjects()
    local hrp = getHumanoidRootPart()
    if not hrp then return {} end
    if #CachedDoors == 0 then return getObjects(DOOR_NAMES) end
    local found = {}
    for _, obj in ipairs(CachedDoors) do
        if obj and obj.Parent then
            local part = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or (obj:IsA("BasePart") and obj or nil)
            if part then  -- nil when obj is a pure container Model (e.g. "Doors" folder)
                table.insert(found, { obj = obj, part = part, dist = (hrp.Position - part.Position).Magnitude })
            end
        end
    end
    table.sort(found, function(a, b) return a.dist < b.dist end)
    return found
end
function groupDoors(doors, radius)
    radius = radius or 350
    local groups = {}
    local used = {}
    for i, d in ipairs(doors) do
        if not used[i] then
            local group = { d }
            used[i] = true
            for j, d2 in ipairs(doors) do
                if not used[j] then
                    if (d.part.Position - d2.part.Position).Magnitude < radius then
                        table.insert(group, d2)
                        used[j] = true
                    end
                end
            end
            local sum = Vector3.new(0, 0, 0)
            for _, gd in ipairs(group) do sum = sum + gd.part.Position end
            table.insert(groups, { doors = group, center = sum / #group, count = #group })
        end
    end
    return groups
end
function teleportNextDoor()
    if not doorCycle.list or #doorCycle.list == 0 then
        local allDoors = getDoorObjects()
        local groups = groupDoors(allDoors, 350)
        doorCycle.list = {}
        for _, g in ipairs(groups) do
            local visited = false
            for _, d in ipairs(g.doors) do if doorCycle.visited[d.obj] then visited = true break end end
            if not visited then table.insert(doorCycle.list, g) end
        end
        if #doorCycle.list == 0 then
            doorCycle.visited = {}
            for _, g in ipairs(groups) do table.insert(doorCycle.list, g) end
        end
        if #doorCycle.list == 0 then print("[VS] No doors found") return end
        local hrp = getHumanoidRootPart()
        if hrp then
            table.sort(doorCycle.list, function(a, b)
                return (hrp.Position - a.center).Magnitude < (hrp.Position - b.center).Magnitude
            end)
        end
    end
    local group = table.remove(doorCycle.list, 1)
    if not group then return end
    for _, d in ipairs(group.doors) do doorCycle.visited[d.obj] = true end
    for _, d in ipairs(group.doors) do
        if d.part and d.part.Parent then
            dungMoveTo(d.part)
            task.wait(0.15)
        end
        interactWith(d.obj)
        task.wait(0.25)
    end
end
autoChestLoop = function()
    Dungeon.autoChest.on = true
    while Dungeon.autoChest.on do
        local chestsFolder = workspace:FindFirstChild("Chests")
        if not chestsFolder then task.wait(2) continue end
        local hrp = getHumanoidRootPart()
        if not hrp then task.wait(1) continue end
        local chests = {}
        for _, obj in ipairs(chestsFolder:GetChildren()) do
            local part = obj:IsA("BasePart") and obj or (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart"))
            if part then table.insert(chests, { obj = obj, part = part, dist = (hrp.Position - part.Position).Magnitude }) end
        end
        if #chests == 0 then
            -- No chests left — fire auto-die if enabled
            if Dungeon.autoDieOnClear then
                task.wait(0.5)
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = 0 end
            end
            task.wait(2)
            continue
        end
        table.sort(chests, function(a, b) return a.dist < b.dist end)
        for _, c in ipairs(chests) do
            if not Dungeon.autoChest.on then break end
            if not c.obj or not c.obj.Parent then continue end
            dungMoveTo(c.part)
            task.wait(0.2)
            interactWith(c.obj)
            task.wait(0.5)
        end
        task.wait(1)
    end
    Dungeon.autoChest.on = false
end
autoDoorLoop = function()
    Dungeon.autoDoor.on = true
    while Dungeon.autoDoor.on do
        if not doorCycle.list or #doorCycle.list == 0 then
            local allDoors = getDoorObjects()
            local groups = groupDoors(allDoors, 350)
            doorCycle.list = {}
            for _, g in ipairs(groups) do
                local visited = false
                for _, d in ipairs(g.doors) do if doorCycle.visited[d.obj] then visited = true break end end
                if not visited then table.insert(doorCycle.list, g) end
            end
            if #doorCycle.list == 0 then
                doorCycle.visited = {}
                for _, g in ipairs(groups) do table.insert(doorCycle.list, g) end
            end
            if #doorCycle.list == 0 then task.wait(2) continue end
            local hrp = getHumanoidRootPart()
            if hrp then
                table.sort(doorCycle.list, function(a, b)
                    return (hrp.Position - a.center).Magnitude < (hrp.Position - b.center).Magnitude
                end)
            end
        end
        if not Dungeon.autoDoor.on then break end
        local group = table.remove(doorCycle.list, 1)
        if not group then task.wait(2) continue end
        for _, d in ipairs(group.doors) do
            if not Dungeon.autoDoor.on then break end
            if d.part and d.part.Parent then
                dungMoveTo(d.part)
                task.wait(0.15)
            end
            interactWith(d.obj)
            task.wait(0.25)
        end
        for _, d in ipairs(group.doors) do doorCycle.visited[d.obj] = true end
        task.wait(1)
    end
    Dungeon.autoDoor.on = false
end

