function mkSlider(p, title, min, max, initial, color, onChange)
    -- Restore saved value (clamped to current min/max)
    if SliderSave[title] then initial = math.clamp(SliderSave[title], min, max) end
    local wrap = Instance.new("Frame") wrap.Size = UDim2.new(1, 0, 0, 54) wrap.BackgroundColor3 = C.PANEL wrap.BorderSizePixel = 0 wrap.Parent = p
    Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 2)
    local accent = Instance.new("Frame") accent.Size = UDim2.new(0, 2, 1, 0) accent.BackgroundColor3 = color accent.BackgroundTransparency = 0.3 accent.BorderSizePixel = 0 accent.Parent = wrap
    local topRow = Instance.new("Frame") topRow.Size = UDim2.new(1, -12, 0, 22) topRow.Position = UDim2.new(0, 10, 0, 6) topRow.BackgroundTransparency = 1 topRow.Parent = wrap
    local titleL = Instance.new("TextLabel") titleL.Size = UDim2.new(1, -50, 1, 0) titleL.BackgroundTransparency = 1 titleL.Text = title titleL.TextColor3 = C.TXT titleL.TextSize = 11 titleL.Font = Enum.Font.Gotham titleL.TextXAlignment = Enum.TextXAlignment.Left titleL.Parent = topRow
    local valL = Instance.new("TextLabel") valL.Size = UDim2.new(0, 46, 1, 0) valL.Position = UDim2.new(1, -46, 0, 0) valL.BackgroundTransparency = 1 valL.Text = tostring(math.floor(initial)) valL.TextColor3 = color valL.TextSize = 11 valL.Font = Enum.Font.GothamBold valL.TextXAlignment = Enum.TextXAlignment.Right valL.Parent = topRow
    local track = Instance.new("Frame") track.Size = UDim2.new(1, -20, 0, 4) track.Position = UDim2.new(0, 10, 0, 34) track.BackgroundColor3 = C.OFF track.BorderSizePixel = 0 track.Parent = wrap Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local pct = (initial - min) / (max - min)
    local fill = Instance.new("Frame") fill.Size = UDim2.new(pct, 0, 1, 0) fill.BackgroundColor3 = color fill.BorderSizePixel = 0 fill.Parent = track Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame") knob.Size = UDim2.new(0, 12, 0, 12) knob.Position = UDim2.new(pct, -6, 0.5, -6) knob.BackgroundColor3 = C.TXT knob.BorderSizePixel = 0 knob.ZIndex = 5 knob.Parent = track Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    local function update(absX)
        local p2 = math.clamp((absX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + p2 * (max - min))
        fill.Size = UDim2.new(p2, 0, 1, 0) knob.Position = UDim2.new(p2, -6, 0.5, -6) valL.Text = tostring(val)
        onSliderChanged(title, val)
        onChange(val)
    end
    local kb = Instance.new("TextButton") kb.Size = UDim2.new(1, 0, 1, 0) kb.BackgroundTransparency = 1 kb.Text = "" kb.ZIndex = 6 kb.Parent = track
    kb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true update(i.Position.X) end end)
    kb.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position.X) end end)
    -- Apply saved value immediately so the game variable matches the displayed value
    onChange(initial)
end
