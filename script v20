function parseServerLink(input)
    if not input or input == "" then return nil end
    -- New share URL: roblox.com/share?code=XXXX&type=Server
    local shareCode = input:match("[?&]code=([^&%s]+)")
    if shareCode then return shareCode end
    -- Old URL: ...?privateServerLinkCode=XXXXX
    local oldCode = input:match("privateServerLinkCode=([^&%s]+)")
    if oldCode then return oldCode end
    -- Raw code (hex/alphanumeric)
    if input:match("^[A-Za-z0-9_%-]+$") then return input end
    return nil
end

function doRejoinPrivateServer()
    local raw = AutoRejoin.linkCode
    if not raw or raw == "" then
        warn("[VS] AutoRejoin: no private server link saved")
        return
    end
    -- Always use AutoRejoin.placeId (lobby place). Default = 6198225400.
    -- game.PlaceId is a WORLD sub-place and will cause error 524.
    local pid = (AutoRejoin.placeId and AutoRejoin.placeId ~= 0) and AutoRejoin.placeId or 6198225400
    local code = parseServerLink(raw)
    task.wait(2)
    -- Attempt 1: LaunchExperience with parsed code (correct format for Roblox API)
    if code then
        local ok, err = pcall(function()
            game:GetService("ExperienceService"):LaunchExperience({ placeId = pid, linkCode = code })
        end)
        if ok then return end
        warn("[VS] LaunchExperience(code) failed: " .. tostring(err))
    end
    -- Attempt 2: LaunchExperience with raw URL (some executors accept this)
    local ok2, err2 = pcall(function()
        game:GetService("ExperienceService"):LaunchExperience({ placeId = pid, linkCode = raw })
    end)
    if ok2 then return end
    warn("[VS] LaunchExperience(raw) failed: " .. tostring(err2))
    -- Attempt 3: TeleportToPrivateServer fallback
    if code then
        local ok3, err3 = pcall(function()
            game:GetService("TeleportService"):TeleportToPrivateServer(pid, code, { LocalPlayer })
        end)
        if not ok3 then warn("[VS] TeleportToPrivateServer failed: " .. tostring(err3)) end
    end
end

-- Called after each CharacterAdded when AutoRejoin is on — clicks the world button in the main menu
function autoSelectWorld()
    if not AutoRejoin.on then return end
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local opening = playerGui:WaitForChild("Opening", 30)
    if not opening then warn("[VS] AutoRejoin: Opening GUI not found") return end
    task.wait(2) -- wait for menu to fully render
    local target = "World" .. AutoRejoin.world  -- e.g. "World1" or "World2"
    -- Try direct name match first, then partial search
    local btn = opening:FindFirstChild(target, true)
    if not btn then
        for _, obj in ipairs(opening:GetDescendants()) do
            if (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
                local n = obj.Name:lower()
                if n:find("world") and n:find(tostring(AutoRejoin.world)) then
                    btn = obj break
                end
            end
        end
    end
    if btn then
        pcall(function() firesignal(btn.MouseButton1Click) end)
    else
    end
end

