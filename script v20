UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    for hkKey, active in pairs(bindingMode) do
        if active then
            if input.KeyCode == Enum.KeyCode.Escape then
                bindingMode[hkKey] = false
                local ref = hkRefs[hkKey]
                if ref then TS:Create(ref.btn, TweenInfo.new(0.1), { BackgroundColor3 = Hotkeys[hkKey] and C.PURP or C.OFF }):Play() ref.lbl.Text = Hotkeys[hkKey] and Hotkeys[hkKey].Name:sub(1, 2):upper() or "" end
                return
            end
            Hotkeys[hkKey] = input.KeyCode bindingMode[hkKey] = false
            local ref = hkRefs[hkKey]
            if ref then TS:Create(ref.btn, TweenInfo.new(0.1), { BackgroundColor3 = C.PURP }):Play() ref.lbl.Text = input.KeyCode.Name:sub(1, 2):upper() end
            return
        end
    end
    for hkKey, keyCode in pairs(Hotkeys) do
        if input.KeyCode == keyCode then
            local act = hkActions[hkKey]
            if act and act.setter then act.setter(not act.state) end
        end
    end
end)

