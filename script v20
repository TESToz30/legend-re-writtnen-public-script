farmLoop = function()
    Farm.on = true
    -- Wait until the world Mobs folder exists (may still be in lobby after rejoin)
    local waitStart = tick()
    while Farm.on and not workspace:FindFirstChild("Mobs") and tick() - waitStart < 60 do
        task.wait(1)
    end
    if not Farm.on or not workspace:FindFirstChild("Mobs") then
        Farm.on = false
        return
    end
    -- Also wait for HumanoidRootPart to be ready
    local waitStart2 = tick()
    while Farm.on and not getHumanoidRootPart() and tick() - waitStart2 < 15 do
        task.wait(0.5)
    end
    if not Farm.on or not getHumanoidRootPart() then
        Farm.on = false
        return
    end
    startFloat()
    startNoclip()
    while Farm.on do
        -- Check if any specific mob is selected in the dropdown
        local anySelected = false
        for _, v in pairs(SelectedMobs) do if v then anySelected = true break end end

        local mob
        if not anySelected then
            -- Nothing selected: tween to whatever alive mob is nearest, no name filter
            local h = getHumanoidRootPart()
            local f = workspace:FindFirstChild("Mobs")
            if h and f then
                local best, bd = nil, math.huge
                for _, m in ipairs(f:GetChildren()) do
                    if m:IsA("Model") and isAlive(m) then
                        local r = getRootPart(m)
                        if r then
                            local d = (h.Position - r.Position).Magnitude
                            if d < bd then bd = d best = m end
                        end
                    end
                end
                mob = best
            end
        else
            mob = findMob()
        end

        if not mob then task.wait(COMBAT_CONFIG.Retry) continue end
        Farm.mob = mob
        tweenTo(mob)
        if not Farm.on then break end
        while Farm.on and mob and mob.Parent and isAlive(mob) do
            hoverAbove(mob, COMBAT_CONFIG.Poll)
            attackMob(mob)
            task.wait(COMBAT_CONFIG.Poll)
        end
        if not Farm.on then break end
        -- Check AutoRejoin trigger
        if AutoRejoin.on and mob then
            local anyTrigger = false
            for _, v in pairs(AutoRejoin.mobs) do if v then anyTrigger = true break end end
            local matches = (not anyTrigger) or (AutoRejoin.mobs[mob.Name] == true)
            if matches then
                Farm.mob = nil
                Farm.on = false
                stopFloat()
                stopNoclip()
                task.spawn(doRejoinPrivateServer)
                return
            end
        end
        Farm.mob = nil
        task.wait(1.5)
    end
    stopFloat()
    stopNoclip()
    Farm.on = false
    Farm.mob = nil
end

