-- Hover
-- BodyPosition drives all movement — no competing CFrame tween (that was causing jitter)
function hoverAbove(mob, dt)
    local r = getRootPart(mob)
    if not r then return end
    local tp
    if Farm.staticHover then
        tp = r.Position + Vector3.new(0, HOVER, 0)
    else
        dt = dt or 0.2
        octAngle = (octAngle + OCT_S * dt) % (math.pi * 2)
        tp = r.Position + Vector3.new(math.cos(octAngle) * OCT_R, HOVER, math.sin(octAngle) * OCT_R)
    end
    if not (floatBP and floatBP.Parent) then startFloat() end
    if floatBP then floatBP.Position = tp end
end

-- Travel to mob — tweens floatBP.Position (not HumanoidRootPart CFrame),
-- so physics follows a smoothly moving target with no conflicts or snap.
function tweenTo(target)
    if Farm.tweening then return end
    Farm.tweening = true
    -- Zero out BodyPosition during travel so the CFrame tween has full control
    if floatBP and floatBP.Parent then
        floatBP.MaxForce = Vector3.new(0, 0, 0)
    end
    while Farm.tweening and target and target.Parent do
        local h = getHumanoidRootPart()
        if not h then break end
        local r = getRootPart(target)
        if not r or not target.Parent then break end
        local tp = r.Position + Vector3.new(0, HOVER, 0)
        local d = (h.Position - tp).Magnitude
        if d < 4 then break end
        local duration = math.clamp(d / MOVEMENT_CONFIG.Speed, 0.3, 8)
        local tw = TS:Create(h, TweenInfo.new(duration, MOVEMENT_CONFIG.Style, MOVEMENT_CONFIG.Direction), { CFrame = CFrame.new(tp) })
        tw:Play()
        tw.Completed:Wait()
        break
    end
    -- Restore Y-only hold
    if floatBP and floatBP.Parent then
        floatBP.MaxForce = Vector3.new(0, math.huge, 0)
    end
    Farm.tweening = false
end

