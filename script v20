local ALL_MOBS = { "Law", "Divine General", "AbyssKnight", "Ant King", "Hiraglacir", "SeaKing1", "LightningGod", "Water Slayer", "Sorcerer Slayer", "SpaceElf", "VintageSpacer", "UFO", "Tanzaknite", "Pharaoh", "RoninA", "RoninB", "Dragon", "Light Paladen", "Melioofus", "Kaze", "Regulus", "Legendary" }
function isMobSelected(n)
    local any = false
    for _, v in pairs(SelectedMobs) do if v then any = true break end end
    if not any then return true end
    for pat, sel in pairs(SelectedMobs) do
        if sel and string.find(n, pat) then return true end
    end
    return false
end
function findMob()
    local h = getHumanoidRootPart()
    if not h then return nil end
    local f = workspace:FindFirstChild("Mobs")
    if not f then return nil end
    local best, bd = nil, math.huge
    for _, m in ipairs(f:GetChildren()) do
        if m:IsA("Model") and isAlive(m) and isMobSelected(m.Name) then
            local r = getRootPart(m)
            if r then
                local d = (h.Position - r.Position).Magnitude
                if d < bd then bd = d best = m end
            end
        end
    end
    return best
end

