function attackMob(mob)
    local h, r = getHumanoidRootPart(), getRootPart(mob)
    if not h or not r then return end
    if (h.Position - r.Position).Magnitude > HOVER + COMBAT_CONFIG.Range then return end
    local n = tick()
    if n - lastAtk < COMBAT_CONFIG.Cooldown then return end
    lastAtk = n
    local p = r.Position
    aimAt(p)
    if ChargeR then pcall(function() ChargeR:FireServer(p.X, p.Y, p.Z) end) end
    if ActivateR then pcall(function() ActivateR:FireServer(p.X, p.Y, p.Z) end) end
