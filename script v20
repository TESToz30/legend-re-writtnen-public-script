local RANKS = { "S", "A", "B", "C", "D", "E" }
function getAllGates()
    local f = workspace:FindFirstChild("Gates")
    if not f then return {} end
    local g = {}
    for _, m in ipairs(f:GetChildren()) do
        local p = m:FindFirstChild("Gate")
        if p then
            local tp = p:FindFirstChild("TPinProgress")
            if tp and tp.Value then continue end
            table.insert(g, {
                model = m, part = p,
                rank = (p:FindFirstChild("Rank") or {}).Value or "?",
                map = (p:FindFirstChild("MapName") or {}).Value or "?",
                boss = (p:FindFirstChild("Boss") or {}).Value or "",
                level = (p:FindFirstChild("Level") or {}).Value or 0,
                gtype = m.Name,
            })
        end
    end
    return g
end
function findGate()
    local h = getHumanoidRootPart()
    local gs = getAllGates()
    local out = {}
    for _, g in ipairs(gs) do
        if (Gate.rank == nil or g.rank == Gate.rank) and (Gate.gtype == nil or g.gtype == Gate.gtype) then
            table.insert(out, g)
        end
    end
    if #out == 0 then return nil end
    if h then
        table.sort(out, function(a, b)
            return (h.Position - a.part.Position).Magnitude < (h.Position - b.part.Position).Magnitude
        end)
    end
    return out[1]
end
function enterGate(g)
    local h = getHumanoidRootPart()
    if not h then return end
    local cf = CFrame.new(g.part.Position + Vector3.new(0, 5, 0))
    local d = (h.Position - cf.Position).Magnitude
    TS:Create(h, TweenInfo.new(math.clamp(d / MOVEMENT_CONFIG.Speed, 0.05, 5), MOVEMENT_CONFIG.Style, MOVEMENT_CONFIG.Direction), { CFrame = cf }):Play()
    task.wait(math.clamp(d / MOVEMENT_CONFIG.Speed, 0.05, 5) + 0.3)
    local jp = g.part:FindFirstChild("JoinParty")
    local rt = g.part:FindFirstChild("ReadyTag")
    if jp then jp:FireServer() end
    task.wait(0.5)
    if rt then rt:FireServer() end
end

