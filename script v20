-- GATE FARM LOOP
-- =====================================================
function getWaveCenters()
    local proj = workspace:FindFirstChild("Projectiles")
    if not proj then return {} end
    local waves = {}
    for _, p in ipairs(proj:GetChildren()) do
        if p:IsA("BasePart") then
            local wn = tonumber(p.Name:match("^Wave(%d+)Spawn%d+$"))
            if wn then
                waves[wn] = waves[wn] or {}
                table.insert(waves[wn], p.Position)
            end
        end
    end
    local centers = {}
    for n, positions in pairs(waves) do
        local sum = Vector3.new(0, 0, 0)
        for _, pos in ipairs(positions) do sum = sum + pos end
        table.insert(centers, { wave = n, pos = sum / #positions, count = #positions })
    end
    table.sort(centers, function(a, b) return a.wave < b.wave end)
    return centers
end
function mobsNearPos(pos, radius)
    local f = workspace:FindFirstChild("Mobs")
    if not f then return {} end
    local list = {}
    for _, m in ipairs(f:GetChildren()) do
        if m:IsA("Model") and isAlive(m) then
            local r = getRootPart(m)
            if r and (r.Position - pos).Magnitude < radius then
                table.insert(list, m)
            end
        end
    end
    return list
end
function gateFarmLoop()
    Gate.farmOn = true
    startFloat()
    startNoclip()
    while Gate.farmOn do
        local centers = getWaveCenters()
        if #centers == 0 then
            local f = workspace:FindFirstChild("Mobs")
            if f then
                local h = getHumanoidRootPart()
                if h then
                    local best, bd = nil, math.huge
                    for _, m in ipairs(f:GetChildren()) do
                        if m:IsA("Model") and isAlive(m) then
                            local r = getRootPart(m)
                            if r then
                                local d = (h.Position - r.Position).Magnitude
                                if d < bd then bd = d best = m end
                            end
                        end
                    end
                    if best then
                        Gate.farmMob = best
                        while Gate.farmOn and best and best.Parent and isAlive(best) do
                            hoverAbove(best, COMBAT_CONFIG.Poll)
                            attackMob(best)
                            task.wait(COMBAT_CONFIG.Poll)
                        end
                        Gate.farmMob = nil
                    end
                end
            end
            task.wait(1)
            continue
        end
        local function killMob(mob)
            if not mob or not mob.Parent or not isAlive(mob) then return end
            Gate.farmMob = mob
            local h2 = getHumanoidRootPart()
            if not h2 then Gate.farmMob = nil return end
            local r = getRootPart(mob)
            if r and (h2.Position - r.Position).Magnitude > HOVER + COMBAT_CONFIG.Range then
                local tp2 = r.Position + Vector3.new(0, HOVER, 0)
                local dd = (h2.Position - tp2).Magnitude
                local tw = TS:Create(h2, TweenInfo.new(math.clamp(dd / MOVEMENT_CONFIG.Speed, 0.05, 2), MOVEMENT_CONFIG.Style, MOVEMENT_CONFIG.Direction), { CFrame = CFrame.new(tp2) })
                tw:Play()
                tw.Completed:Wait()
            end
            while Gate.farmOn and mob and mob.Parent and isAlive(mob) do
                hoverAbove(mob, COMBAT_CONFIG.Poll)
                attackMob(mob)
                task.wait(COMBAT_CONFIG.Poll)
            end
            Gate.farmMob = nil
        end
        for _, center in ipairs(centers) do
            if not Gate.farmOn then break end
            local h = getHumanoidRootPart()
            if not h then break end
            local tp = center.pos + Vector3.new(0, HOVER, 0)
            local d = (h.Position - tp).Magnitude
            if d > 5 then
                local tw = TS:Create(h, TweenInfo.new(math.clamp(d / MOVEMENT_CONFIG.Speed, 0.1, 4), MOVEMENT_CONFIG.Style, MOVEMENT_CONFIG.Direction), { CFrame = CFrame.new(tp) })
                tw:Play()
                tw.Completed:Wait()
            end
            -- Kill all mobs near this center — no timeout, only exits when all dead
            while Gate.farmOn do
                local mobs = mobsNearPos(center.pos, 400)
                if #mobs == 0 then break end
                local h2 = getHumanoidRootPart()
                if not h2 then break end
                local best, bd = nil, math.huge
                for _, m in ipairs(mobs) do
                    local r = getRootPart(m)
                    if r then
                        local dd = (h2.Position - r.Position).Magnitude
                        if dd < bd then bd = dd best = m end
                    end
                end
                killMob(best)
            end
        end
        -- Final straggler sweep — kill any remaining mobs in workspace.Mobs
        if Gate.farmOn then
            local f = workspace:FindFirstChild("Mobs")
            if f then
                while Gate.farmOn do
                    local h2 = getHumanoidRootPart()
                    if not h2 then break end
                    local best, bd = nil, math.huge
                    for _, m in ipairs(f:GetChildren()) do
                        if m:IsA("Model") and isAlive(m) then
                            local r = getRootPart(m)
                            if r then
                                local dd = (h2.Position - r.Position).Magnitude
                                if dd < bd then bd = dd best = m end
                            end
                        end
                    end
                    if not best then break end
                    killMob(best)
                end
            end
        end
        task.wait(2)
    end
    stopFloat()
    stopNoclip()
    Gate.farmOn = false
    Gate.farmMob = nil
end

