do
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local function raidClickButton(button)
        if not button then return false end
        pcall(function()
            for _, sig in ipairs({ "Activated", "MouseButton1Click", "MouseButton1Down" }) do
                local s = button[sig]
                if s and typeof(s) == "RBXScriptSignal" then if firesignal then firesignal(s) end end
            end
        end)
        return true
    end
    local function raidWaitPath(root, path, timeout)
        timeout = timeout or 10
        local cur = root
        for _, name in ipairs(path) do
            cur = cur:WaitForChild(name, timeout)
            if not cur then warn("[VS Raid] Missing: " .. name) return nil end
        end
        return cur
    end
    local function doUrukRaid()
        Raid.status = "Opening Raids menu..."
        local opening = playerGui:WaitForChild("Opening", 10)
        if not opening then Raid.status = "ERR: Opening GUI not found" return end
        local raidsBtn = raidWaitPath(opening, { "GameOptions", "Raids" })
        if not raidsBtn then Raid.status = "ERR: Raids button not found" return end
        raidClickButton(raidsBtn) task.wait(0.5)
        Raid.status = "Opening Uruk frame..."
        local urukBtn = raidWaitPath(opening, { "RaidFrame", "Uruk" })
        if not urukBtn then Raid.status = "ERR: Uruk button not found" return end
        raidClickButton(urukBtn) task.wait(0.5)
        local createBtn = raidWaitPath(opening, { "RaidFrame", "UrukFrame", "Create" })
        if createBtn and createBtn.Visible then Raid.status = "Creating party..." raidClickButton(createBtn) task.wait(1) end
        Raid.status = "Waiting for Start..."
        local startBtn = raidWaitPath(opening, { "RaidFrame", "UrukFrame", "Start" })
        local waited = 0
        while startBtn and not startBtn.Visible and waited < 15 do task.wait(0.25) waited += 0.25 end
        if startBtn and startBtn.Visible then
            raidClickButton(startBtn) Raid.status = "Started!" print("[VS Raid] Uruk raid started")
        else
            Raid.status = "ERR: Start btn never appeared"
        end
        Raid.on = false
    end
    startUrukRaid = function()
        if Raid.on then return end
        Raid.on = true Raid.status = "Starting..."
        Raid.thread = task.spawn(function()
            while Raid.on do doUrukRaid() if Raid.on then task.wait(3) end end
        end)
    end
    stopRaid = function()
        Raid.on = false
