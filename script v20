function oreAlive(o)
    if not o or not o.Parent then return false end
    local h = o:FindFirstChild("HP")
    return h and h.Value > 0
end
function findOre()
    local h = getHumanoidRootPart()
    if not h then return nil end
    local f = workspace:FindFirstChild("Ores")
    if not f then return nil end
    local any = false
    for _, v in pairs(Mine.selected) do if v then any = true break end end
    local best, bd = nil, math.huge
    for _, o in ipairs(f:GetChildren()) do
        if o:IsA("Model") and oreAlive(o) then
            if any and not Mine.selected[o.Name] then continue end
            local r = o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart")
            if r then
                local d = (h.Position - r.Position).Magnitude
                if d < bd then bd = d best = o end
            end
        end
    end
    return best
end
