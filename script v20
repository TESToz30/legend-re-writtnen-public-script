local function setupDiedListener(char)
    if not char then return end
    -- WaitForChild so we don't miss it if the character is still loading
    local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 10)
    if not hum then return end
    hum.Died:Connect(function()
        if AutoRejoin.on then
            task.spawn(doRejoinPrivateServer)
        end
    end)
end
-- Hook current character — wait for it if not loaded yet
task.spawn(function()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    setupDiedListener(char)
end)
LocalPlayer.CharacterAdded:Connect(function(char)
    stopFloat() stopNoclip() Farm.tweening = false
    if Farm.on then Farm.on = false task.wait(3) task.spawn(farmLoop) end
    setupDiedListener(char)
    if AutoRejoin.on then task.spawn(autoSelectWorld) end
    if Invisible.on then task.wait(0.5) setInvisible(true) end
end)

