    end
end
function isAlive(o)
    if not o or not o.Parent then return false end
    local h = o:FindFirstChild("Health")
    if h and h:IsA("IntValue") then return h.Value > 0 end
    local hm = o:FindFirstChildOfClass("Humanoid")
    if hm then return hm.Health > 0 end
    return false
end
