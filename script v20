    local pctL = Instance.new("TextLabel") pctL.Size = UDim2.new(0, 46, 1, 0) pctL.Position = UDim2.new(1, -46, 0, 0) pctL.BackgroundTransparency = 1 pctL.Text = math.floor(autoPotionThreshold * 100) .. "%" pctL.TextColor3 = C.RED pctL.TextSize = 11 pctL.Font = Enum.Font.GothamBold pctL.TextXAlignment = Enum.TextXAlignment.Right pctL.Parent = topRow
    local track = Instance.new("Frame") track.Size = UDim2.new(1, -20, 0, 4) track.Position = UDim2.new(0, 10, 0, 34) track.BackgroundColor3 = C.OFF track.BorderSizePixel = 0 track.Parent = wrap Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame") fill.Size = UDim2.new(autoPotionThreshold, 0, 1, 0) fill.BackgroundColor3 = C.RED fill.BorderSizePixel = 0 fill.Parent = track Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame") knob.Size = UDim2.new(0, 12, 0, 12) knob.Position = UDim2.new(autoPotionThreshold, -6, 0.5, -6) knob.BackgroundColor3 = C.TXT knob.BorderSizePixel = 0 knob.ZIndex = 5 knob.Parent = track Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
